# ============================================================
# HIGHWAY - Self-hosted deployment platform
# ============================================================

# ── Database (PostgreSQL on Contabo VPS) ────────────────────
DATABASE_URL=postgresql://highway:password@localhost:5432/highway

# ── Redis (on Contabo VPS) ─────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── GitHub OAuth App ────────────────────────────────────────
# Create at: https://github.com/settings/applications/new
# Homepage URL: https://highway.yourdomain.com
# Callback URL: https://api.highway.yourdomain.com/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── GitHub Webhook Secret ───────────────────────────────────
GITHUB_WEBHOOK_SECRET=your-random-secret-here

# ── JWT ─────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# ── Coolify (running on Contabo VPS) ────────────────────────
# Get API token from: Coolify dashboard → Keys & Tokens
COOLIFY_URL=https://coolify.yourdomain.com
COOLIFY_API_TOKEN=
# Your main server UUID from Coolify (Settings → Servers)
COOLIFY_SERVER_UUID=

# ── App URLs ────────────────────────────────────────────────
API_URL=https://api.highway.yourdomain.com
WEB_URL=https://highway.yourdomain.com

# Development
# API_URL=http://localhost:3001
# WEB_URL=http://localhost:3000

PORT=3001
