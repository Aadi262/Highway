{
  "name": "highway",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "bun@1.3.10",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "db:generate": "turbo run db:generate --filter=@highway/db",
    "db:migrate": "turbo run db:migrate --filter=@highway/db",
    "db:studio": "turbo run db:studio --filter=@highway/db"
  },
  "dependencies": {
    "drizzle-orm": "0.45.1"
  },
  "overrides": {
    "drizzle-orm": "0.45.1"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  }
}